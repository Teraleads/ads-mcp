# ─── Google Ads ───────────────────────────────────────────────────────────────
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=          # Without dashes, e.g. 1234567890
GOOGLE_ADS_MANAGER_ID=           # Optional: MCC account ID

# ─── Meta (Facebook / Instagram) Ads ──────────────────────────────────────────
META_ACCESS_TOKEN=                # Long-lived user access token
META_AD_ACCOUNT_ID=               # e.g. act_123456789012345
META_APP_ID=
META_APP_SECRET=

# ─── TikTok Ads ───────────────────────────────────────────────────────────────
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# ─── LinkedIn Ads ──────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ACCOUNT_ID=              # LinkedIn ad account URN number only

# ─── Northbeam ────────────────────────────────────────────────────────────────
NORTHBEAM_API_KEY=
NORTHBEAM_BRAND=                  # Your brand slug in Northbeam

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3003
TRANSPORT=stdio                   # "stdio" (local) or "http" (remote/DigitalOcean)
API_SECRET=                      # Required when TRANSPORT=http — Bearer token for auth
